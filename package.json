{
  "name": "aprendo",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@aprendo/web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@aprendo/db",
    "ingest": "turbo run ingest --filter=@aprendo/ingest"
  },
  "trustedDependencies": [
    "esbuild",
    "lightningcss"
  ],
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
